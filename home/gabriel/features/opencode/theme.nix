{colorscheme}: let
  c = colorscheme.colors;
in {
  primary = { dark = c.primary; light = c.primary; };
  secondary = { dark = c.secondary; light = c.secondary; };
  accent = { dark = c.tertiary; light = c.tertiary; };
  error = { dark = c.error; light = c.error; };
  warning = { dark = c.orange; light = c.orange; };
  success = { dark = c.green; light = c.green; };
  info = { dark = c.blue; light = c.blue; };
  text = { dark = c.on_surface; light = c.on_surface; };
  textMuted = { dark = c.on_surface_variant; light = c.on_surface_variant; };
  background = { dark = c.surface; light = c.surface; };
  backgroundPanel = { dark = c.surface_container; light = c.surface_container; };
  backgroundElement = { dark = c.surface_container_high; light = c.surface_container_high; };
  border = { dark = c.outline_variant; light = c.outline_variant; };
  borderActive = { dark = c.outline; light = c.outline; };
  borderSubtle = { dark = c.surface_container_highest; light = c.surface_container_highest; };
  diffAdded = { dark = c.green; light = c.green; };
  diffRemoved = { dark = c.red; light = c.red; };
  diffContext = { dark = c.outline; light = c.outline; };
  diffHunkHeader = { dark = c.surface_container_high; light = c.surface_container_high; };
  diffHighlightAdded = { dark = c.on_green; light = c.on_green; };
  diffHighlightRemoved = { dark = c.on_red; light = c.on_red; };
  diffAddedBg = { dark = c.green_container; light = c.green_container; };
  diffRemovedBg = { dark = c.red_container; light = c.red_container; };
  diffContextBg = { dark = c.surface_container; light = c.surface_container; };
  diffLineNumber = { dark = c.outline; light = c.outline; };
  diffAddedLineNumberBg = { dark = c.green_container; light = c.green_container; };
  diffRemovedLineNumberBg = { dark = c.red_container; light = c.red_container; };
  markdownText = { dark = c.on_surface; light = c.on_surface; };
  markdownHeading = { dark = c.primary; light = c.primary; };
  markdownLink = { dark = c.blue; light = c.blue; };
  markdownLinkText = { dark = c.on_blue; light = c.on_blue; };
  markdownCode = { dark = c.green; light = c.green; };
  markdownBlockQuote = { dark = c.outline_variant; light = c.outline_variant; };
  markdownEmph = { dark = c.orange; light = c.orange; };
  markdownStrong = { dark = c.yellow; light = c.yellow; };
  markdownHorizontalRule = { dark = c.outline; light = c.outline; };
  markdownListItem = { dark = c.cyan; light = c.cyan; };
  markdownListEnumeration = { dark = c.magenta; light = c.magenta; };
  markdownImage = { dark = c.blue; light = c.blue; };
  markdownImageText = { dark = c.on_blue_container; light = c.on_blue_container; };
  markdownCodeBlock = { dark = c.on_surface; light = c.on_surface; };
  syntaxComment = { dark = c.outline; light = c.outline; };
  syntaxKeyword = { dark = c.magenta; light = c.magenta; };
  syntaxFunction = { dark = c.blue; light = c.blue; };
  syntaxVariable = { dark = c.cyan; light = c.cyan; };
  syntaxString = { dark = c.green; light = c.green; };
  syntaxNumber = { dark = c.yellow; light = c.yellow; };
  syntaxType = { dark = c.orange; light = c.orange; };
  syntaxOperator = { dark = c.magenta; light = c.magenta; };
  syntaxPunctuation = { dark = c.on_surface; light = c.on_surface; };
}
